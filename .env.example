# Authentication
NEXTAUTH_SECRET=replace_with_strong_random_secret
NEXTAUTH_URL=http://localhost:3000

# Database (use local/staging database in development)
DATABASE_URL=postgresql://user:password@localhost:5432/levav_tms_dev

# AWS S3 (documents/uploads)
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your_bucket_name
AWS_FOLDER_PREFIX=dev/

# External PDF service token
ABACUSAI_API_KEY=replace_with_service_token

# Claude API для страницы /agents (сейчас не используется в коде extract-ветки,
# но переменные оставлены в .env.local — не удалять)
ANTHROPIC_API_KEY=sk-ant-replace_with_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini API для extract-ветки /api/agents/document (бесплатный тариф)
GEMINI_API_KEY=replace_with_gemini_key
